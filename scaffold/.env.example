# Lexis — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# All secrets stored in Railway/Vercel/GitHub Actions — not here.

# ─── DATABASE ───────────────────────────────────────────
# Supabase pooled connection (PgBouncer) — for runtime queries
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Direct connection (bypasses PgBouncer) — for prisma migrate deploy ONLY
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ─── REDIS ──────────────────────────────────────────────
# Upstash Redis REST URL
REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6380

# ─── AUTH ────────────────────────────────────────────────
# Minimum 32 characters, random string
JWT_SECRET=change-me-to-a-random-32-char-minimum-secret

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# WebAuthn — must match your domain exactly
WEBAUTHN_RP_ID=lexis.app
WEBAUTHN_RP_ORIGIN=https://lexis.app
# For local development:
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_ORIGIN=http://localhost:3000

# ─── STORAGE (Cloudflare R2) ────────────────────────────
# Zero egress fees. S3-compatible.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=lexis-prod
# Public media URL (served via Cloudflare CDN, DNS-only on media.lexis.app)
R2_PUBLIC_URL=https://media.lexis.app
# R2 endpoint for AWS SDK
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ─── EMAIL (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=hello@lexis.app

# ─── BILLING (Stripe) ────────────────────────────────────
# Use sk_test_ on staging, sk_live_ on production
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_xxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxx
STRIPE_PRICE_GROWTH_MONTHLY=price_xxxx
STRIPE_PRICE_GROWTH_ANNUAL=price_xxxx

# ─── AI (Anthropic) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ─── REALTIME SERVER ────────────────────────────────────
RT_PORT=4000
RT_CORS_ORIGIN=https://lexis.app
# Local: RT_CORS_ORIGIN=http://localhost:3001

# ─── API SERVER ──────────────────────────────────────────
PORT=3000
API_URL=https://api.lexis.app
# Local: API_URL=http://localhost:3000

# ─── WEB ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.lexis.app
NEXT_PUBLIC_RT_URL=https://rt.lexis.app
NEXT_PUBLIC_APP_ENV=production

# ─── ENVIRONMENT ─────────────────────────────────────────
NODE_ENV=production
APP_ENV=production
# Values: local | staging | production

# ─── OBSERVABILITY ──────────────────────────────────────
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
LOG_LEVEL=info
# Values: debug | info | warn | error
